#!/usr/bin/env bash

# shellcheck disable=1091,2086

set -euo pipefail
export SETVARS_CALL=${SETVARS_CALL:-0}
cd "$GITHUB_WORKSPACE"

time make env cudascript=ursa INSTALLDIR="$INSTALLDIR"

source conda/etc/profile.d/conda.sh
conda activate base
command -v uw >/dev/null || {
  echo ERROR: 'uw' not found after make devenv
  exit 1
}
uw --version || true

# Define helpers.

slurm_wait() {
  local job_id="$1"
  local label="${2:-job}"
  local prev=""
  echo Waiting for $label job $job_id ...
  while true; do
    local state=""
    state="$(squeue -h -j "$job_id" -o "%T" 2>/dev/null || true)"
    if [[ -z "$state" ]]; then
      state="$(sacct -j "$job_id" --format=State --noheader 2>/dev/null | head -n1 | awk '{print $1}')"
      state="${state:-UNKNOWN}"
    fi
    if [[ "$state" != "$prev" ]]; then
      echo "$label ($job_id) state: $state"
      prev="$state"
    fi
    case "$state" in
    COMPLETED)
      echo "$label ($job_id) COMPLETED"
      break
      ;;
    FAILED* | CANCELLED* | TIMEOUT* | NODE_FAIL* | OUT_OF_MEMORY*)
      echo "$label ($job_id) terminal failure: $state"
      return 1
      ;;
    esac
    sleep 20
  done
  return 0
}

wait_runscript_batch() {
  local dir="$1"
  local target="$2"
  local label="${3:-$target}"

  local submit="$dir/runscript.$target.submit"
  local done="$dir/runscript.$target.done"
  local out="$dir/runscript.$target.out"

  if [[ ! -d "$dir" ]]; then
    echo ERROR: Missing run directory: $dir
    exit 1
  fi

  if [[ ! -f "$submit" ]]; then
    echo ERROR: Missing submit file: $submit
    ls -la "$dir" || true
    exit 1
  fi

  local job_id
  job_id="$(grep -oE '[0-9]+' "$submit" | tail -n1)"
  if [[ -z "${job_id:-}" ]]; then
    echo ERROR: Could not parse numeric job id from $submit
    cat "$submit" || true
    exit 1
  fi

  if ! slurm_wait "$job_id" "$label"; then
    [[ -f "$out" ]] && tail -n 200 "$out" || true
    exit 1
  fi

  if [[ ! -f "$done" ]]; then
    echo ERROR: Job completed but .done marker missing: $done
    [[ -f "$out" ]] && tail -n 200 "$out" || true
    exit 1
  fi
}

# Build config.

EXP="ci-pr$PR_NUM-$(echo $SHA | cut -c1-7)"
echo Experiment name: $EXP

make config compose=base:nested:ursa INSTALLDIR="$INSTALLDIR" >eagle.yaml

BASEDIR="$GITHUB_WORKSPACE"

cat <<EOF >update.yaml
app:
  base: $BASEDIR
  experiment_name: $EXP
inference:
  anemoi:
    checkpoint_path: $BASEDIR/run/$EXP/training/outputs/checkpoint
EOF
uw config realize -i eagle.yaml -o eagle.yaml -u update.yaml

make validate config=eagle.yaml INSTALLDIR="$INSTALLDIR"

RUNROOT="$BASEDIR/run/$EXP"

# Run data-prep and check artifacts.

make data config=eagle.yaml INSTALLDIR="$INSTALLDIR"

for datasource in gfs hrrr; do
  wait_runscript_batch "$RUNROOT/data" "zarr-$datasource" "Zarr $datasource"
done

for datasource in gfs hrrr; do
  test -d "$RUNROOT/data/$datasource.zarr" || {
    echo Missing $RUNROOT/data/$datasource.zarr
    exit 1
  }
done

# Run training.

make training config=eagle.yaml INSTALLDIR="$INSTALLDIR"
wait_runscript_batch "$RUNROOT/training" "training" "Training"

# Run inference and check artifacts.

make inference config=eagle.yaml INSTALLDIR="$INSTALLDIR"
wait_runscript_batch "$RUNROOT/inference" "inference" "Inference"

find "$RUNROOT/inference" -type f -name "*.nc" -print -quit | grep -q . || {
  echo ERROR: No inference NetCDF outputs found under $RUNROOT/inference
  exit 1
}

# Run verification and check artifacts.

for truth in grid obs; do
  for extent in global lam; do
    make vx-$truth-$extent config=eagle.yaml INSTALLDIR="$INSTALLDIR"
  done
done

for truth in grid obs; do
  for extent in global lam; do
    wait_runscript_batch "$RUNROOT/vx/grid2$truth/$extent" "wxvx-grid2$truth-$extent" "VX grid2$truth $extent"
  done
done

find "$RUNROOT/vx" -type f -name "*.png" -print -quit | grep -q . || {
  echo ERROR: No verification PNGs found under $RUNROOT/vx
  exit 1
}

find "$RUNROOT/vx" -type f -name "*.stat" -print -quit | grep -q . || {
  echo ERROR: No verification .stat outputs found under $RUNROOT/vx
  exit 1
}

# Run visualization and check artifacts.

for truth in grid obs; do
  for extent in global lam; do
    make vis-$truth-$extent config=eagle.yaml INSTALLDIR="$INSTALLDIR"
  done
done

for truth in grid obs; do
  for extent in global lam; do
    dir=$RUNROOT/visualization/grid2$truth/$extent/plots-basic
    count=$(find $dir -type f -name "*.png" | wc -l)
    expected=8
    test $count -eq $expected || {
      echo ERROR: Found $count PNG files in $dir, expected $expected
      exit 1
    }
  done
done

for extent in global lam; do
  dir=$RUNROOT/visualization/grid2grid/$extent/plots-spatial-stats
  count=$(find $dir -type f -name "*.png" | wc -l)
  expected=8
  test $count -eq $expected || {
    echo ERROR: Found $count PNG files in $dir, expected $expected
    exit 1
  }
done

# Generate NRT config, realize it, run data prep, and run inference.

cat <<EOF >update.yaml
app:
  base: $BASEDIR
  experiment_name: $EXP
inference:
  anemoi:
    checkpoint_path: $BASEDIR/run/$EXP/training/outputs/checkpoint
EOF
make config compose=base:nested:ursa:nrt-nested >nrt-composed.yaml
make realize config=nrt-composed.yaml update=update.yaml >nrt.yaml

# Define NRTDIR in terms of NOW variable (changes every run).

NRTDIR="$(uw config realize -i nrt.yaml --key-path app.rundir)"

make data config=nrt.yaml
for datasource in gfs hrrr; do
  wait_runscript_batch "$NRTDIR/data" "zarr-$datasource" "Zarr $datasource"
done

make inference config=nrt.yaml
wait_runscript_batch "$NRTDIR/inference" "inference" "NRT Inference"

find "$NRTDIR/inference/output" -type f -name "*.nc" -print -quit | grep -q . || {
  echo ERROR: No inference NetCDF outputs found under $NRTDIR/inference
  exit 1
}

# Done.

echo NRT EAGLE CI pipeline completed successfully in $NRTDIR
